# Supabase — pegue em Project Settings > API no seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — NUNCA expor no client. Usada só em rotas server-side (cron de lembretes).
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app (usada nos redirects de OAuth). Em dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# IA — geração de legendas e insights (console.anthropic.com)
ANTHROPIC_API_KEY=

# --- Integrações sociais (preencher conforme cada app review for aprovado) ---
# Meta (Instagram + Facebook) — developers.facebook.com
META_APP_ID=
META_APP_SECRET=

# TikTok for Developers — developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# LinkedIn Marketing Developer Platform — linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# YouTube Data API (Google Cloud Console)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
